# This tweak facilitates key passthrough. If you bind, say, the F1-key to an
# action in your window manager, you can no longer use F1 in applications
# unless you have some key that temporarily disables the binding. You could
# press that key manually, press F1, and re-enable the binding. This does all
# that in a sequence for each key, so that everything that you press while
# holding Fn-z (ie. PrtSc/SysRq) will get passed through to an application. It
# assumes that your passthrough key is `M-cancel` and your re-enabling key is
# `cancel`. 

[Fn]
z = overload(Passthrough, sysrq)

[Passthrough]
q = macro(M-cancel esc cancel)
w = macro(M-cancel home cancel)
e = macro(M-cancel up cancel)
r = macro(M-cancel end cancel)
t = macro(M-cancel sysrq cancel)

a = macro(M-cancel noop cancel)
s = macro(M-cancel left cancel)
d = macro(M-cancel down cancel)
f = macro(M-cancel right cancel)
g = macro(M-cancel delete cancel)

z = macro(M-cancel noop cancel)
x = macro(M-cancel compose cancel)
c = macro(M-cancel pageup cancel)
v = macro(M-cancel pagedown cancel)
b = macro(M-cancel capslock cancel)

y = macro(M-cancel f10 cancel)
u = macro(M-cancel f7 cancel)
i = macro(M-cancel f8 cancel)
o = macro(M-cancel f9 cancel)
p = macro(M-cancel insert cancel)

h = macro(M-cancel f11 cancel)
j = macro(M-cancel f4 cancel)
k = macro(M-cancel f5 cancel)
l = macro(M-cancel f6 cancel)
; = macro(M-cancel pause cancel)
' = macro(M-cancel rightcontrol cancel)

n = macro(M-cancel f12 cancel)
m = macro(M-cancel f1 cancel)
, = macro(M-cancel f2 cancel)
. = macro(M-cancel f3 cancel)
/ = macro(M-cancel scrolllock cancel)
rightshift = macro(M-cancel rightmeta cancel)

