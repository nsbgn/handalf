# Pressing Tab in Fn emits Alt-Tab, but it also keeps the Alt modifier active
# until you press another key. This mimics behaviour when window switching with
# Alt-Tab normally.

[Fn]
tab = swapm(AltTabFn, A-tab)

[AltTabFn:A]
space = swapm(Fn, space)

q = swapm(Fn, esc)
w = swapm(Fn, home)
e = swapm(Fn, up)
r = swapm(Fn, end)
t = swapm(Fn, pageup)

a = swapm(Fn, noop)
s = swapm(Fn, left)
d = swapm(Fn, down)
f = swapm(Fn, right)
g = swapm(Fn, pagedown)

z = swapm(Fn, sysrq)
x = swapm(Fn, cut)
c = swapm(Fn, copy)
v = swapm(Fn, paste)
b = swapm(Fn, delete)

y = swapm(Fn, f10)
u = swapm(Fn, f7)
i = swapm(Fn, f8)
o = swapm(Fn, f9)
p = swapm(Fn, pause)

h = swapm(Fn, f11)
j = swapm(Fn, f4)
k = swapm(Fn, f5)
l = swapm(Fn, f6)
; = swapm(Fn, rightmeta)
' = swapm(Fn, compose)

n = swapm(Fn, f12)
m = swapm(Fn, f1)
, = swapm(Fn, f2)
. = swapm(Fn, f3)
/ = swapm(Fn, scrolllock)
rightshift = swapm(Fn, insert)

