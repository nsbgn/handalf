default partial alphanumeric_keys xkb_symbols "basic" {
    include "us(basic)"
    include "handalf(level3)"
    include "handalf(cancel)"
    include "handalf(shift_level3_multi)"
    name[Group1]= "Handalf";
};

partial alphanumeric_keys xkb_symbols "colemak_dh" {
    include "us(colemak_dh_ortho)"
    include "handalf(level3)"
    include "handalf(cancel)"
    include "handalf(shift_level3_multi)"
    name[Group1]= "Handalf (Colemak)";
};

partial modifier_keys xkb_symbols "caps_backspace" {
    key <CAPS> { [ BackSpace, BackSpace, BackSpace ] };
};

partial modifier_keys xkb_symbols "shift_level3_multi" {
    key <LFSH> { type[Group1]="THREE_LEVEL", [ Shift_L,  Multi_key,  Multi_key ] };
    key <RTSH> { type[Group1]="THREE_LEVEL", [ Shift_R,  Multi_key,  Multi_key ] };
    key <RALT> { type[Group1]="THREE_LEVEL", [ ISO_Level3_Shift, Multi_key,  Multi_key ] };
};

partial modifier_keys xkb_symbols "cancel" {
    key <STOP> { type[Group1]="ONE_LEVEL", [ Cancel ] };
    key <I231> { type[Group1]="ONE_LEVEL", [ Cancel ] };
};

partial alphanumeric_keys xkb_symbols "level3" {
    key.type = "THREE_LEVEL";
    key <TAB> { [ NoSymbol, NoSymbol, Tab ] };
    key <AD01> { [ NoSymbol, NoSymbol, exclam ] }; // q
    key <AD02> { [ NoSymbol, NoSymbol, bracketleft ] }; // w
    key <AD03> { [ NoSymbol, NoSymbol, plus ] }; // e
    key <AD04> { [ NoSymbol, NoSymbol, numbersign ] }; // r
    key <AD05> { [ NoSymbol, NoSymbol, bracketright ] }; // t
    key <AD06> { [ NoSymbol, NoSymbol, asciicircum ] }; // y
    key <AD07> { [ NoSymbol, NoSymbol, 7 ] }; // u
    key <AD08> { [ NoSymbol, NoSymbol, 8 ] }; // i
    key <AD09> { [ NoSymbol, NoSymbol, 9 ] }; // o
    key <AD10> { [ NoSymbol, NoSymbol, percent ] }; // p
    // key <BKSL> { [ backslash, backslash, backslash ] }; // backslash
    // The above remapping is done on the keycode level, so that you can still
    // generate a pipe with just keycodes, whether this layout is active or not

    key <AC01> { [ NoSymbol, NoSymbol, asterisk ] }; // a
    key <AC02> { [ NoSymbol, NoSymbol, parenleft ] }; // s
    key <AC03> { [ NoSymbol, NoSymbol, minus ] }; // d
    key <AC04> { [ NoSymbol, NoSymbol, equal ] }; // f
    key <AC05> { [ NoSymbol, NoSymbol, parenright ] }; // g
    key <AC06> { [ NoSymbol, NoSymbol, at ] }; // h
    key <AC07> { [ NoSymbol, NoSymbol, 4 ] }; // j
    key <AC08> { [ NoSymbol, NoSymbol, 5 ] }; // k
    key <AC09> { [ NoSymbol, NoSymbol, 6 ] }; // l
    key <AC10> { [ NoSymbol, NoSymbol, 0 ] }; // semicolon
    key <AC11> { [ NoSymbol, NoSymbol, grave ] }; // apostrophe

    key <AB01> { [ NoSymbol, NoSymbol, bar ] }; // z
    key <AB02> { [ NoSymbol, NoSymbol, braceleft ] }; // x
    key <AB03> { [ NoSymbol, NoSymbol, dollar ] }; // c
    key <AB04> { [ NoSymbol, NoSymbol, underscore ] }; // v
    key <AB05> { [ NoSymbol, NoSymbol, braceright ] }; // b
    key <AB06> { [ NoSymbol, NoSymbol, ampersand ] }; // n
    key <AB07> { [ NoSymbol, NoSymbol, 1 ] }; // m
    key <AB08> { [ NoSymbol, NoSymbol, 2 ] }; // comma
    key <AB09> { [ NoSymbol, NoSymbol, 3 ] }; // period
    key <AB10> { [ NoSymbol, NoSymbol, asciitilde ] }; // slash
};
